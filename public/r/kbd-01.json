{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "kbd-01",
  "title": "KBD 01 - KBD in Button",
  "description": "Buttons with inline keyboard shortcut hints with Mac/Windows platform switch",
  "dependencies": [
    "lucide-react"
  ],
  "registryDependencies": [
    "kbd",
    "button",
    "switch"
  ],
  "files": [
    {
      "path": "src/components/shadcn-space/kbd/kbd-01.tsx",
      "content": "'use client'\r\n\r\nimport { useState } from 'react'\r\nimport { PrinterIcon, SaveIcon, Share2Icon } from 'lucide-react'\r\nimport { Button } from '@/components/ui/button'\r\nimport { Kbd, KbdGroup } from '@/components/ui/kbd'\r\nimport { Switch } from '@/components/ui/switch'\r\n\r\ntype Platform = 'mac' | 'win'\r\n\r\nconst KbdInButtonDemo = () => {\r\n  const [platform, setPlatform] = useState<Platform>('mac')\r\n  const isMac = platform === 'mac'\r\n\r\n  return (\r\n    <div className=\"flex flex-col items-center gap-4\">\r\n      {/* Platform switch */}\r\n      <div className=\"flex items-center gap-2 text-sm\">\r\n        <span className=\"text-muted-foreground\">MacOS</span>\r\n        <Switch\r\n          checked={platform === 'win'}\r\n          onCheckedChange={(checked) => setPlatform(checked ? 'win' : 'mac')}\r\n        />\r\n        <span className=\"text-muted-foreground\">Windows</span>\r\n      </div>\r\n\r\n      {/* Buttons */}\r\n      <div className=\"flex flex-wrap justify-center gap-3\">\r\n        <Button variant=\"outline\" className=\"hover:bg-muted/40\">\r\n          <SaveIcon aria-hidden=\"true\" />\r\n          Save\r\n          <KbdGroup className=\"-me-1\">\r\n            <Kbd>{isMac ? '⌘' : 'Ctrl'}</Kbd>\r\n            <Kbd>S</Kbd>\r\n          </KbdGroup>\r\n        </Button>\r\n\r\n        <Button variant=\"outline\" className=\"hover:bg-muted/40\">\r\n          <PrinterIcon aria-hidden=\"true\" />\r\n          Print\r\n          <KbdGroup className=\"-me-1\">\r\n            <Kbd>{isMac ? '⌘' : 'Ctrl'}</Kbd>\r\n            <Kbd>P</Kbd>\r\n          </KbdGroup>\r\n        </Button>\r\n\r\n        <Button variant=\"outline\" className=\"hover:bg-muted/40\">\r\n          <Share2Icon aria-hidden=\"true\" />\r\n          Share\r\n          <KbdGroup className=\"-me-1\">\r\n            <Kbd>{isMac ? '⌘' : 'Ctrl'}</Kbd>\r\n            <Kbd>{isMac ? '⇧' : 'Shift'}</Kbd>\r\n            <Kbd>S</Kbd>\r\n          </KbdGroup>\r\n        </Button>\r\n      </div>\r\n    </div>\r\n  )\r\n}\r\n\r\nexport default KbdInButtonDemo\r\n",
      "type": "registry:component",
      "target": "@components/shadcn-space/kbd/kbd-01.tsx"
    }
  ],
  "type": "registry:component"
}